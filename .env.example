TOKEN=
SUPER_ADMIN=Kasante01
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=123456
DB_DATABASE=thuchi
MESSAGE_START="Bot is running"

# Múi giờ ghi close / chốt ngày / created_at phiên & giao dịch (mặc định VN; server UTC không bị lệch ngày).
# APP_TIMEZONE=Asia/Ho_Chi_Minh

# Tuỳ chọn: dọn DB — xóa phiên đã close và transactions > N ngày (mặc định 3).
# PURGE_CLOSED_DAYS=3
# PURGE_INTERVAL_SEC=3600
# PURGE_START_DELAY_SEC=120

# Tuỳ chọn: sau +/- chỉ hiển thị N giao dịch mới nhất (mặc định 3). data / close luôn hiện đủ.
# TX_DISPLAY_AFTER_TRADE=3

# Tuỳ chọn an toàn: nếu data/close gặp phiên quá lớn, chỉ render phần đuôi để bot không treo.
# TX_FULL_RENDER_MAX=500
# TX_FULL_RENDER_TAIL=150
